{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/proxy(.*)", "dest": "/api/index.js" },
    { "src": "/stream(.*)", "dest": "/api/index.js" },
    { "src": "/(.*\\.(html|js|css|png|jpg|jpeg|gif|svg|ico|webp|json))", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
